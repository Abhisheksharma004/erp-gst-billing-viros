# Environment Variables
# Copy this file to .env and fill in the values

# Database (app uses DB_* — not DATABASE_URL)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=viros_gst_new
DB_PORT=3306

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-long-random-secret"

# Optional one-time Super Admin seed (only if no superadmin exists yet)
# SUPERADMIN_EMAIL="admin@example.com"
# SUPERADMIN_PASSWORD="use-a-strong-password"

# SMTP (Forgot Password OTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-16-char-app-password"

# Application
APP_NAME="Viros GST Billing"
APP_URL="http://localhost:3000"
